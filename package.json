{
  "name": "@particle-academy/fancy-features",
  "version": "0.1.0",
  "description": "Headless, zero-dependency feature-management engine (boolean + metered-resource gating, feature groups, quota usage). The Node/TypeScript mirror of the PHP particle-academy/laravel-fms — and the owner of the shared feature contract consumed by @particle-academy/fancy-catalog.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-features-js.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-features-js#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-features-js/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "feature-flags",
    "feature-management",
    "entitlements",
    "gating",
    "quota",
    "metering",
    "billing",
    "fms",
    "headless",
    "fancy",
    "human-plus"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
